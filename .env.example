# Beispiel-Umgebungsvariablen für Pflegekreuzer
# Kopiere diese Datei als .env oder nutze /etc/pflegeweb.env

APP_LOGIN_USER=abrechnung@froehlichdienste.de
APP_LOGIN_PASSWORD=change_me_securely
CONFIG_PASSWORD=change_me_securely
# Alternativ kannst du gehashte Passwörter im pbkdf2_sha256-Format verwenden.
# APP_LOGIN_PASSWORD=pbkdf2_sha256$200000$...$...
# CONFIG_PASSWORD=pbkdf2_sha256$200000$...$...

APP_AUTH_COOKIE_NAME=app_auth
AUTH_COOKIE_NAME=cfg_auth
APP_AUTH_COOKIE_SECRET=change_me_secret
CFG_AUTH_COOKIE_SECRET=change_me_secret
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
DATABASE_URL=postgresql+psycopg2://pflege:pflegepass@localhost:5432/pflege
